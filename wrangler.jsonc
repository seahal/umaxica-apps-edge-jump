{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "umaxica-apps-edge-jump",
  "main": "src/cloudflare.ts",
  "compatibility_date": "2026-05-26",
  "compatibility_flags": ["nodejs_compat"],
  "version_metadata": {
    "binding": "CF_VERSION_METADATA"
  },
  "ratelimits": [
    {
      "name": "RATE_LIMITER",
      "namespace_id": "1002",
      "simple": {
        "limit": 100,
        "period": 60
      }
    }
  ],
  "secrets_store_secrets": [
    {
      "binding": "JUMP_PRIVATE_KEY_PEM",
      "store_id": "eb74dec1a757471281526676fb6e6509",
      "secret_name": "JUMP_PRIVATE_KEY_PEM"
    }
  ],
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "env": {
    "development": {}
  }
}
