{
  "name": "umaxica-apps-jump-app-core",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 5402",
    "build": "vp exec opennextjs-cloudflare build",
    "build:next": "next build",
    "start": "next start --port 5402",
    "deploy": "vp exec opennextjs-cloudflare build && vp exec opennextjs-cloudflare deploy",
    "deploy:upload": "vp exec opennextjs-cloudflare build && vp exec opennextjs-cloudflare upload",
    "deploy:promote": "vp exec wrangler versions deploy --yes",
    "preview": "vp exec opennextjs-cloudflare build && vp exec opennextjs-cloudflare preview",
    "cf-typegen": "vp exec wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "catalog:",
    "@sentry/nextjs": "^10.51.0",
    "client-only": "^0.0.1",
    "next": "catalog:",
    "nuqs": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  },
  "browserslist": [
    "chrome 111",
    "edge 111",
    "firefox 111",
    "safari 16.4"
  ]
}
